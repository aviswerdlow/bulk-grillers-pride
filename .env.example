# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-secret-here
# Your Clerk issuer URL (found in Clerk Dashboard → API Keys)
CLERK_ISSUER_URL=https://your-app.clerk.accounts.dev

# Convex
# Get this from https://dashboard.convex.dev
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Optional: AI Services
# For AI-powered categorization features
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Additional Services
# Add any additional service keys here

# Optional: Sentry Error Monitoring (Production Only)
# Uncomment these lines if you want to use Sentry
# NEXT_PUBLIC_SENTRY_DSN=https://your-public-dsn@sentry.io/project-id
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-auth-token