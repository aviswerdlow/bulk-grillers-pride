{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "remoteCache": {
    "signature": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "!README.md", "!./**/*.test.*"],
      "env": ["NODE_ENV", "NEXT_PUBLIC_*", "CLERK_*", "CONVEX_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", ".eslintrc.*", "!./**/*.test.*"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "jest.setup.*", "./**/*.test.*", "./**/__tests__/**"],
      "env": ["NODE_ENV", "NEXT_PUBLIC_*", "CLERK_*", "CONVEX_*", "TEST_*"]
    },
    "test:ci": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "jest.setup.*", "./**/*.test.*", "./**/__tests__/**"],
      "env": ["NODE_ENV", "NEXT_PUBLIC_*", "CLERK_*", "CONVEX_*", "TEST_*", "CI"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.*", "!./**/*.test.*"]
    },
    "clean": {
      "cache": false
    },
    "analyze": {
      "dependsOn": ["build"],
      "outputs": [".next/analyze/**"],
      "cache": false
    }
  }
}
