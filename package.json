{
  "name": "bulk-grillers-pride",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant SaaS application for e-commerce product merchandising with AI-powered categorization",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' jest",
    "test:safe": "NODE_OPTIONS='--max-old-space-size=2048' jest --maxWorkers=2 --bail",
    "test:sequential": "NODE_OPTIONS='--max-old-space-size=2048' jest --runInBand",
    "test:single": "NODE_OPTIONS='--max-old-space-size=2048' jest --maxWorkers=1",
    "test:web": "NODE_OPTIONS='--max-old-space-size=2048' jest --selectProjects=web",
    "test:convex": "NODE_OPTIONS='--max-old-space-size=2048' jest --selectProjects=convex",
    "test:factories": "NODE_OPTIONS='--max-old-space-size=2048' jest --selectProjects=test-factories",
    "test:emergency": "NODE_OPTIONS='--max-old-space-size=1024' jest --runInBand --no-cache --bail",
    "test:incremental": "node scripts/test-runner.js",
    "test:watch": "NODE_OPTIONS='--max-old-space-size=4096' jest --watch",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=4096' jest --coverage",
    "test:ci": "NODE_OPTIONS='--max-old-space-size=4096' jest --ci --coverage --maxWorkers=50%",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:a11y": "NODE_OPTIONS='--max-old-space-size=4096' jest --testPathPattern='accessibility' && playwright test accessibility",
    "test:a11y:unit": "NODE_OPTIONS='--max-old-space-size=4096' jest --testPathPattern='accessibility'",
    "test:a11y:e2e": "playwright test accessibility",
    "test:a11y:axe": "playwright test --project=chromium --grep 'should not have accessibility violations'",
    "coverage:record": "node scripts/track-coverage.js record",
    "coverage:report": "node scripts/track-coverage.js report",
    "coverage:check": "node scripts/track-coverage.js check",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf coverage",
    "dev:web": "cd apps/web && npm run dev",
    "dev:convex": "cd convex && npx convex dev",
    "setup": "node scripts/setup.js",
    "setup:quick": "npm install && npm run convex:setup",
    "convex:setup": "cd convex && npx convex dev --once",
    "convex:deploy": "cd convex && npx convex deploy",
    "validate:clerk": "node scripts/validate-clerk-jwt.js",
    "prepare": "husky",
    "turbo:prune": "turbo daemon stop && rm -rf .turbo node_modules/.cache/turbo",
    "cache:analyze": "node scripts/turbo-cache-analytics.js",
    "cache:clear": "rm -rf .turbo/cache",
    "cache:warmup": "turbo run build lint type-check test:ci --force",
    "turbo:login": "turbo login",
    "turbo:link": "turbo link",
    "turbo:daemon:status": "node scripts/turbo-daemon-monitor.js status",
    "turbo:daemon:restart": "node scripts/turbo-daemon-monitor.js restart",
    "turbo:daemon:monitor": "node scripts/turbo-daemon-monitor.js monitor",
    "check-tasks": "node scripts/check-tasks",
    "generate:test": "node scripts/generate-convex-test.js",
    "enable-crewai": "npx tsx scripts/enable-crewai.ts",
    "disable-crewai": "npx tsx scripts/disable-crewai.ts",
    "benchmark:quick": "node scripts/run-benchmark.js --type quick",
    "benchmark:standard": "node scripts/run-benchmark.js --type standard",
    "benchmark:full": "node scripts/run-benchmark.js --type full",
    "benchmark:report": "node scripts/generate-benchmark-report.js",
    "benchmark:check-regression": "node scripts/check-benchmark-regression.js",
    "ci:optimize": "node scripts/optimize-ci.js",
    "ci:analyze": "node scripts/optimize-ci.js",
    "security:check": "npm audit --audit-level=moderate && npx license-checker --production --summary",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.0.0",
    "@next/eslint-plugin-next": "^15.4.4",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "convex-test": "^0.0.38",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.4",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^3.0.1",
    "lint-staged": "^16.1.2",
    "next-router-mock": "^1.0.2",
    "playwright": "^1.54.1",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "tsup": "^8.3.5",
    "tsx": "^4.20.3",
    "turbo": "^2.5.5",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "e-commerce",
    "saas",
    "ai",
    "product-management",
    "categorization",
    "multi-tenant"
  ],
  "author": "Bulk Grillers Pride",
  "license": "MIT",
  "dependencies": {
    "@langchain/openai": "^0.5.18",
    "@radix-ui/react-switch": "^1.2.5",
    "convex": "^1.25.4",
    "recharts": "^3.1.0"
  },
  "packageManager": "npm@11.4.2"
}
