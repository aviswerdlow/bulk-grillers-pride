{
  "name": "bulk-grillers-pride",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant SaaS application for e-commerce product merchandising with AI-powered categorization",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "type-check": "tsc --noEmit",
    "clean": "turbo run clean && rm -rf coverage",
    "dev:web": "cd apps/web && npm run dev",
    "dev:convex": "cd convex && npx convex dev",
    "setup": "node scripts/setup.js",
    "setup:quick": "npm install && npm run convex:setup",
    "convex:setup": "cd convex && npx convex dev --once",
    "convex:deploy": "cd convex && npx convex deploy",
    "validate:clerk": "node scripts/validate-clerk-jwt.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.8.0",
    "eslint": "^8.51.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "jest-watch-typeahead": "^3.0.1",
    "lint-staged": "^16.1.2",
    "next-router-mock": "^1.0.2",
    "playwright": "^1.54.1",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "turbo": "^1.10.16",
    "typescript": "^5.2.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "e-commerce",
    "saas",
    "ai",
    "product-management",
    "categorization",
    "multi-tenant"
  ],
  "author": "Bulk Grillers Pride",
  "license": "MIT",
  "dependencies": {
    "convex": "^1.24.8"
  }
}
