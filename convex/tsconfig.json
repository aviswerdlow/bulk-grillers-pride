{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.node.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    // TypeScript optimization flags to resolve TS2589
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "disableSourceOfProjectReferenceRedirect": true,
    "disableSolutionSearching": true,
    "disableReferencedProjectLoad": true,
    // Additional optimization for complex types
    "skipLibCheck": true,
    "skipDefaultLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.js"
  ],
  "exclude": [
    "node_modules",
    "_generated/server.js",
    "_generated/api.js",
    "**/*.test.ts",
    "**/*.spec.ts",
    "__tests__/**/*",
    ".tsbuildinfo",
    "migrations/**/*"
  ]
}