{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@bulk-grillers-pride/shared-types": ["./packages/shared-types/src"],
      "@bulk-grillers-pride/utils": ["./packages/utils/src"],
      "@bulk-grillers-pride/test-factories": ["./packages/test-factories/src"],
      "@bulk-grillers-pride/convex-test-helpers": ["./packages/convex-test-helpers/src"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "types/**/*.d.ts"],
  "exclude": ["node_modules", ".next", "dist", "coverage", "**/build/**", "**/_generated/**"]
}
